# Supabase — copy these from your project at https://app.supabase.com → Project Settings → API
# Then duplicate this file to `.env.local` and fill in the real values.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# The app's public origin, used for the email-confirmation redirect
# (<NEXT_PUBLIC_SITE_URL>/auth/callback). Must match the Site URL configured in
# the Supabase dashboard (Authentication → URL Configuration).
# Local dev: http://localhost:3000 · Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
